{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "主窗口能力：核心 + 剪贴板写入 + 文件对话框（SSH 配置导入导出）",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-theme",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "dialog:default"
  ]
}
